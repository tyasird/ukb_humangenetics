---
const newsItems = [
  {
    icon: '/images/icon-science.png',
    title: 'Science: Neues zur Infektion mit dem Epstein-Barr-Virus',
    href: '#',
    desc: '19.02.2026 – Bonner Forschende entschlüsseln, wie der menschliche Körper eine weit verbreitete Virusinfektion unter Kontrolle hält',
  },
  {
    icon: '/images/icon-science.png',
    title: 'Science: DNA-Tests von Darmpolypen verbessern den Einblick in erbliche Risiken',
    href: '#',
    desc: '12.01.2026 – Europäische Zusammenarbeit belegt den Wert gezielter Tumoranalysen',
  },
  {
    icon: '/images/icon-news.png',
    title: 'News: Podcast zum Thema „Genetik – selbst Schuld an Krankheiten?"',
    href: '#',
    desc: '04.08.2025 – Prof. Markus Nöthen im Gespräch mit der Journalistin Tina Kirchner von der Podcastfabrik',
  },
]

const eventItems = [
  {
    icon: '/images/icon-lecture.png',
    title: 'Lecture: Genetics of Infertility – from Research to Clinical Application',
    href: '#',
    desc: '11.12.2025, 13:00 Uhr – Frau Dr. med. habil. Margot Wyrwoll – Life & Brain Gebäude, Seminarraum EG',
  },
  {
    icon: '/images/icon-lecture.png',
    title: 'Lecture: Klinische Pharmakogenetik in Diagnostik und Beratung',
    href: '#',
    desc: '17.11.2025, 14:00 Uhr – Dr. Tim Krüger und Herr Jeremias Krause – Life & Brain Gebäude, Seminarraum EG',
  },
  {
    icon: '/images/icon-lecture.png',
    title: 'Lecture: Biological Embedding of Experience — Long-term Consequences of Childhood Adversity',
    href: '#',
    desc: '13.06.2025, 10:00 – Herr Prof. Dr. Robert Kumsta, University of Luxembourg',
  },
]

const columns = [
  { heading: 'Aktuelles aus dem Institut', items: newsItems, allHref: '#' },
  { heading: 'Vorträge / Veranstaltungen', items: eventItems, allHref: '#' },
]
---

<section style="background-color: rgb(247, 247, 247); padding-top: 40px; padding-bottom: 40px;">
  <div style="max-width: 1200px; margin: 0 auto; padding-left: 20px; padding-right: 20px;">
    <div class="news-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px;">
      {columns.map(col => (
        <div>
          <h3
            style="font-size: 18px; font-weight: 400; font-family: Lato, sans-serif; color: rgb(0, 81, 158); margin: 0 0 20px 0; padding-bottom: 10px; border-bottom: 1px solid rgb(225, 225, 225);"
          >
            {col.heading}
          </h3>
          {col.items.map(item => (
            <div
              style="display: flex; gap: 15px; padding-top: 15px; padding-bottom: 15px; border-bottom: 1px solid rgb(225, 225, 225);"
            >
              <img src={item.icon} alt="" width="40" height="40" style="flex-shrink: 0; align-self: flex-start;" />
              <div>
                <a
                  href={item.href}
                  class="news-link"
                  style="color: rgb(0, 81, 158); font-size: 14px; font-weight: 700; text-decoration: none; display: block;"
                >
                  {item.title}
                </a>
                <p style="color: rgb(81, 81, 81); font-size: 13px; margin: 4px 0 0 0; line-height: 1.4;">
                  {item.desc}
                </p>
              </div>
            </div>
          ))}
          <a href={col.allHref} style="color: rgb(0, 81, 158); font-size: 14px; display: block; margin-top: 15px;" class="hover:underline">
            Alle Beiträge
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .news-link:hover { text-decoration: underline; }
  @media (max-width: 639px) {
    .news-grid { grid-template-columns: 1fr !important; }
  }
</style>
