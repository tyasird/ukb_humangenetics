---
const logos = [
  { src: '/images/logo-zentrum-seltene-erkrankungen.png', alt: 'Zentrum für Seltene Erkrankungen Bonn', href: 'https://zseb.ukbonn.de/' },
  { src: '/images/logo-cio.png', alt: 'CIO Centrum für Integrierte Onkologie Köln Bonn', href: 'https://cio.ukbonn.de/' },
  { src: '/images/logo-european-reference-network.png', alt: 'European Reference Network', href: '#' },
  { src: '/images/logo-drnets.png', alt: 'DRNETS Deutsches Referenznetzwerk für erbliche Tumorsyndrome', href: '#' },
]
---

<section style="background-color: #ffffff; padding-top: 40px; padding-bottom: 40px;">
  <div style="max-width: 1200px; margin: 0 auto; padding-left: 20px; padding-right: 20px;">
    <div class="partner-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; align-items: center;">
      {logos.map(logo => (
        <a href={logo.href} target="_blank" rel="noopener noreferrer" class="partner-link">
          <img
            src={logo.src}
            alt={logo.alt}
            width="300"
            height="120"
            style="width: 100%; height: auto; display: block; margin: 0 auto;"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .partner-link {
    display: block;
    transition: opacity 0.15s ease;
  }
  .partner-link:hover { opacity: 0.8; }
  @media (max-width: 767px) {
    .partner-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
