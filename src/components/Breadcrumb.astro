---
interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items?: BreadcrumbItem[]
}

const { items = [{ label: 'Start' }] } = Astro.props
---

<div style="background-color: #ffffff; padding-top: 20px; padding-bottom: 0;">
  <div style="max-width: 1200px; margin: 0 auto; padding-left: 20px; padding-right: 20px;">
    <nav aria-label="Breadcrumb" style="font-size: 14px; color: rgb(81, 81, 81);">
      {items.map((item, index) => (
        <span>
          {index > 0 && (
            <span style="color: rgb(81, 81, 81); margin: 0 4px;">&gt;</span>
          )}
          {item.href ? (
            <a
              href={item.href}
              style="color: rgb(81, 81, 81); text-decoration: none;"
              class="hover:underline"
            >
              {item.label}
            </a>
          ) : (
            <span style="color: rgb(81, 81, 81);">{item.label}</span>
          )}
        </span>
      ))}
    </nav>
  </div>
</div>
