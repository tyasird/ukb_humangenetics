---

<PageShell
  activeHref="/institut/"
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: 'Institut', href: '/institut/' },
    { label: 'Mitarbeiter' },
  ]}
  title="Mitarbeiter - Institut für Humangenetik"
>
  <ContentPage title="Mitarbeiter">
    <p style="margin-bottom: 16px;">
      Telefonnummern – Biomedizinischen Zentrum (BMZ) und Forschungszentrum Life &amp; Brain (Genomics)
    </p>
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 14px; color: rgb(81, 81, 81);">
        <thead>
          <tr style="background-color: rgb(0, 81, 158); color: #fff; text-align: left;">
            <th style="padding: 8px 12px; font-weight: 700;">Name</th>
            <th style="padding: 8px 12px; font-weight: 700;">E-Mail</th>
            <th style="padding: 8px 12px; font-weight: 700;">Tel. BMZ</th>
            <th style="padding: 8px 12px; font-weight: 700;">Tel. Genomics</th>
          </tr>
        </thead>
        <tbody>
          {staff.map((person, idx) => (
            <tr style={`border-bottom: 1px solid #e5e7eb; background-color: ${idx % 2 === 0 ? '#fff' : '#f9fafb'};`}>
              <td style="padding: 8px 12px; font-weight: 500; white-space: nowrap;">{person.name}</td>
              <td style="padding: 8px 12px;">
                {person.email
                  ? <a href={`mailto:${person.email}`} style="color: rgb(0, 81, 158);">{person.email}</a>
                  : ''}
              </td>
              <td style="padding: 8px 12px; white-space: nowrap;">{person.telBMZ}</td>
              <td style="padding: 8px 12px; white-space: nowrap;">{person.telGenomics}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </ContentPage>
</PageShell>
