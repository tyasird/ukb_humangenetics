---

<PageShell
  activeHref="/beratung/"
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: 'Beratung', href: '/beratung/' },
    { label: 'Unsere Ärztinnen und Ärzte' },
  ]}
  title="Unsere Ärztinnen und Ärzte - Institut für Humangenetik"
>
  <ContentPage title="Unsere Ärztinnen & Ärzte">
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 14px; color: rgb(81, 81, 81);">
        <tbody>
          {doctors.map((doc, i) => (
            <tr style={`background-color: ${i % 2 === 0 ? '#f7f7f7' : '#ffffff'}; border-bottom: 1px solid #e8e8e8;`}>
              <td style="padding: 10px 12px; font-weight: 700;">{doc.name}</td>
              <td style="padding: 10px 12px;">{doc.role}</td>
              <td style="padding: 10px 12px;">{doc.tel}</td>
              <td style="padding: 10px 12px;">
                <a href={`mailto:${doc.email}`} style="color: rgb(0, 81, 158);">{doc.email}</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </ContentPage>
</PageShell>
